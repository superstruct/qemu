prefix=/home/isaac/src/superstruct/qemu/wasm-deps/target
includedir=${prefix}/include
libdir=${prefix}/lib

gmodule_supported=true

Name: GModule
Description: Dynamic module loader for GLib
Version: 2.84.0
Requires: glib-2.0
Libs: -L${libdir} -lgmodule-2.0 -pthread -sPTHREAD_POOL_SIZE=4
Cflags: -I${includedir} -pthread
